APP_ENV=development

# true = cadastro aceita qualquer texto na chave e não consome licença no banco (fase de testes).
# Em produção use false e chaves de 8 caracteres cadastradas em `licenses`.
SKIP_ACTIVATION_LICENSE_CHECK=true

# JWT / cookies — use um valor longo e aleatório fora do exemplo em produção
SECRET_KEY=troque-esta-chave-em-producao-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

POSTGRES_DB=appgetup
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# Backend dentro do Compose: host = nome do serviço (ex.: postgres). Fora do Compose: localhost
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/appgetup

BACKEND_PORT=8000
FRONTEND_PORT=5173

# Origens permitidas pelo CORS da API (separadas por vírgula)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# URL do front (links no e-mail de recuperação de senha)
APP_URL=http://localhost:5173
PASSWORD_RESET_TOKEN_MAX_AGE=86400

# SMTP (opcional em dev — sem isso o link de reset só aparece no log do backend)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@seudominio.com

# Bootstrap de admin local (NÃO use senha real no versionamento)
# BOOTSTRAP_ADMIN_ENABLED=true
# BOOTSTRAP_ADMIN_EMAIL=admin@local.test
# BOOTSTRAP_ADMIN_PASSWORD=troque-esta-senha
# BOOTSTRAP_ADMIN_NAME=Administrador
# BOOTSTRAP_ADMIN_ACTIVITY_TYPE=Prestação de serviços
# BOOTSTRAP_ADMIN_WHATSAPP=11999999999
